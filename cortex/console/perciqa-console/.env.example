# Auth
CONSOLE_PASSWORD=changeme
COOKIE_SECRET=<32-char random string>

# Argus backend
ARGUS_API_TARGET=http://localhost:8000

# Cortex broker
CORTEX_API_TARGET=http://localhost:8080
NEXT_PUBLIC_CORTEX_WS_EVENTS=ws://localhost:8080/ws/events
NEXT_PUBLIC_CORTEX_WS_METRICS=ws://localhost:8080/ws/metrics

# Argus WS derives from browser host automatically

# Feature flags
NEXT_PUBLIC_ENABLE_ARGUS=false   # set to true to show Argus section in sidebar
